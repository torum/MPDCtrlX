<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="clr-namespace:MPDCtrlX.ViewModels"
			 xmlns:mod="clr-namespace:MPDCtrlX.Models"
			 xmlns:prop="clr-namespace:MPDCtrlX.Properties"
             x:Class="MPDCtrlX.Views.Dialogs.Keybindings">
	<Grid>
		<ScrollViewer Margin="10,10,0,10" Width="480" Height="250" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="0,0,12,0">
			<StackPanel Spacing="14" Margin="0,0,0,24">
				<TextBlock Text="Application Global" FontWeight="Bold" FontSize="16"/>
				<StackPanel Spacing="14" Margin="12,0,0,0">
					<SelectableTextBlock>
						<Run Text="Play/Pause: "/>
						<Run Text="MediaPlay, MediaPlayPause, MediaStop, Ctrl+P, Space(when not focused on list)"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Play Next: "/>
						<Run Text="MediaNextTrack, Ctrl+N, Ctrl+Right"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Play Previous: "/>
						<Run Text="MediaPreviousTrack, Ctrl+B, Ctrl+Left"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Volume Mute: "/>
						<Run Text="VolumeMute"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Volume Down: "/>
						<Run Text="VolumeDown, Ctrl+OemMinus, Ctrl+Subtract"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Volume Up: "/>
						<Run Text="VolumeUp, Ctrl+OemPlus, Ctrl+Add"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Search library: "/>
						<Run Text="Ctrl+S"/>
					</SelectableTextBlock>
				</StackPanel>
				<TextBlock Text="Queue page" FontWeight="Bold" FontSize="16"/>
				<StackPanel Spacing="14" Margin="12,0,0,0">
					<SelectableTextBlock>
						<Run Text="(On the list) Play selected: "/>
						<Run Text="Enter"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="(On the list) Remove selected: "/>
						<Run Text="Ctrl+Delete"/>
					</SelectableTextBlock>
					<SelectableTextBlock>
						<Run Text="Find song in the Queue: "/>
						<Run Text="Ctrl+F"/>
					</SelectableTextBlock>
				</StackPanel>

				<TextBlock Text="Albums page" FontWeight="Bold" FontSize="16"/>
				<StackPanel Spacing="14" Margin="12,0,0,0">
					<SelectableTextBlock>
						<Run Text="Find album in the Albums: "/>
						<Run Text="Ctrl+F"/>
					</SelectableTextBlock>
				</StackPanel>
				<TextBlock Text="Artists page" FontWeight="Bold" FontSize="16"/>
				<StackPanel Spacing="14" Margin="12,0,0,0">
					<SelectableTextBlock>
						<Run Text="Find artist in the Artists: "/>
						<Run Text="Ctrl+F"/>
					</SelectableTextBlock>
				</StackPanel>
				<TextBlock Text="Files page" FontWeight="Bold" FontSize="16"/>
				<StackPanel Spacing="14" Margin="12,0,0,0">
					<SelectableTextBlock>
						<Run Text="Filter files in the Files: "/>
						<Run Text="Ctrl+F"/>
					</SelectableTextBlock>
				</StackPanel>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
